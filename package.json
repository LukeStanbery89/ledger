    "devDependencies": {
        "@jest/types": "^29.3.1",
        "eslint": "^8.31.0",
        "husky": "^8.0.2",
        "jest": "^29.3.1",
        "node-notifier": "^10.0.1",
        "parcel": "^2.8.2"
    }
